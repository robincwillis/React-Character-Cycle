{
  "name": "charcycle",
  "version": "1.0.0",
  "description": "React component to create a character cycling / text scramble effect",
  "author": "Robin Willis",
  "license": "MIT",
  "homepage": "https://robincwillis.github.io/CharCycle/",
  "repository": {
    "type": "git",
    "url": "git://github.com/robincwillis/CharCycle.git"
  },
  "keywords": [
    "react",
    "component",
    "animation",
    "text",
    "cycling",
    "glitch",
    "scramble",
    "typewriter"
  ],
  "main": "dist/charcycle.cjs.js",
  "module": "dist/charcycle.es.js",
  "exports": {
    ".": {
      "import": "./dist/charcycle.es.js",
      "require": "./dist/charcycle.cjs.js"
    }
  },
  "files": [
    "dist",
    "src/CharCycle.jsx",
    "src/index.js"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vite": "^5.0.0"
  }
}
